@page "/python_content/{FileName}"
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Python Script: @FileName</h5>
                </div>
                <div class="card-body">
                    <h6>Script Content:</h6>
                    <textarea class="form-control mb-3"
                              rows="10"
                              value="@PythonContentDisplay"
                              readonly></textarea>

                    <div class="d-flex justify-content-between">
                        <button class="btn btn-success" @onclick="RunPython">Run Script</button>
                        <button class="btn btn-secondary" @onclick="GoBack">Back to List</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="alert alert-info">
                <strong>System Log:</strong> @SystemStatus
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string FileName { get; set; } = "";

    private string PythonContentDisplay = "";
    private string SystemStatus = "Ready.";

    public class ScriptFile
    {
        public string FileName { get; set; } = "";
        public string Content { get; set; } = "";
    }

    private List<ScriptFile> PythonFiles = new();

    protected override void OnInitialized()
    {
        // Populate with dummy data
        PythonFiles = new List<ScriptFile>
        {
            new ScriptFile { FileName = "data_process.py", Content = "import pandas as pd\nprint('Processing data...')" },
            new ScriptFile { FileName = "scraper.py", Content = "import requests\nresponse = requests.get('url')\nprint(response.text)" },
            new ScriptFile { FileName = "utils.py", Content = "def add(a, b):\n    return a + b" },
            new ScriptFile { FileName = "main.py", Content = "if __name__ == '__main__':\n    print('Hello World')" },
            new ScriptFile { FileName = "config.py", Content = "DB_HOST = 'localhost'\nDB_PORT = 5432" }
        };

        var file = PythonFiles.FirstOrDefault(f => f.FileName == FileName);
        if (file != null)
        {
            PythonContentDisplay = file.Content;
            SystemStatus = $"Loaded {FileName}";
        }
        else
        {
            SystemStatus = "File not found.";
            PythonContentDisplay = "File not found.";
        }
    }

    private void RunPython()
    {
        // In a real app, this would call a backend API or a WASM python runner
        SystemStatus = "Executing Python script... Done. (Execution simulated)";
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/python_list");
    }
}