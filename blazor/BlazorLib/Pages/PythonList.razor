@page "/python_list"
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Python Scripts</h5>
                </div>
                <div class="card-body">
                    <h6>Select a Script:</h6>
                    <div class="list-group mb-3" style="max-height: 200px; overflow-y: auto; border: 1px solid #ddd;">
                        @foreach (var file in PythonFiles)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action"
                                    @onclick="() => OpenFile(file)">
                                @file.FileName
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="alert alert-info">
                <strong>System Log:</strong> @SystemStatus
            </div>
        </div>
    </div>
</div>

@code {
    // ==========================================
    // DATA MODELS
    // ==========================================

    // Simple class to represent a file
    public class ScriptFile
    {
        public string FileName { get; set; } = "";
        public string Content { get; set; } = "";
    }

    // ==========================================
    // STATE VARIABLES
    // ==========================================

    // Lists to hold our mock file data
    private List<ScriptFile> PythonFiles = new();

    // Status message to give feedback to the user
    private string SystemStatus = "Ready.";

    // ==========================================
    // INITIALIZATION
    // ==========================================

    protected override void OnInitialized()
    {
        // Populate with dummy data for demonstration
        PythonFiles = new List<ScriptFile>
        {
            new ScriptFile { FileName = "data_process.py", Content = "import pandas as pd\nprint('Processing data...')" },
            new ScriptFile { FileName = "scraper.py", Content = "import requests\nresponse = requests.get('url')\nprint(response.text)" },
            new ScriptFile { FileName = "utils.py", Content = "def add(a, b):\n    return a + b" },
            new ScriptFile { FileName = "main.py", Content = "if __name__ == '__main__':\n    print('Hello World')" },
            new ScriptFile { FileName = "config.py", Content = "DB_HOST = 'localhost'\nDB_PORT = 5432" }
        };
    }

    // ==========================================
    // PYTHON LOGIC
    // ==========================================

    private void OpenFile(ScriptFile file)
    {
        Navigation.NavigateTo($"/python_content/{file.FileName}");
    }
}